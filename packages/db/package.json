{
  "name": "@restaurantos/db",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.js",
  "scripts": {
    "migrate":      "node-pg-migrate -m src/migrations up",
    "migrate:up":   "node-pg-migrate -m src/migrations up",
    "migrate:down": "node-pg-migrate -m src/migrations down",
    "migrate:create": "node-pg-migrate -m src/migrations create",
    "seed":         "node src/seed.js"
  },
  "dependencies": {
    "pg":           "^8.11.3",
    "node-pg-migrate": "^7.3.0",
    "dotenv":       "^16.3.1"
  }
}
